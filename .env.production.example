# ============================================================
# NexistHub — Production Environment
# Copy ke .env di VPS, JANGAN commit file ini dengan nilai asli
# ============================================================

APP_NAME=NexistHub
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# Ganti dengan random string panjang (min 32 char)
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=GANTI_DENGAN_SECRET_KEY_YANG_AMAN

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database — ganti password dengan yang kuat
POSTGRES_USER=nexist_user
POSTGRES_PASSWORD=GANTI_PASSWORD_KUAT_DISINI
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=nexisthub_db

# CORS — ganti dengan IP VPS atau domain Anda
ALLOWED_ORIGINS=["http://72.60.43.158","https://yourdomain.com"]

TIMEZONE=Asia/Makassar
